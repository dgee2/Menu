{
  "extends": "@tsconfig/node22/tsconfig.json",
  "include": [
    "env.node.d.ts",
    "vite.config.*",
    "vitest.config.*",
    "cypress.config.*",
    "nightwatch.conf.*",
    "playwright.config.*",
    "eslint.config.*"
  ],
  "compilerOptions": {
    "noEmit": true,

    "lib": ["es2024"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node"],
    "tsBuildInfoFile": "./build/tsconfig.node.tsbuildinfo"
  }
}
