{
  "name": "menu-website",
  "version": "0.0.1",
  "description": "Menu website",
  "productName": "Menu",
  "author": "Daniel Gee <dan@dan-gee.co.uk>",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "run-p type-check \"build-only {@}\" --",
    "build-only": "vite build",
    "dev": "vite",
    "aspire": "vite --port 5173",
    "format": "prettier --write \"**/*.{js,ts,vue,scss,html,md,json}\" --ignore-path .gitignore",
    "lint": "eslint . \"./src/**/*.{ts,js,cjs,mjs,vue}\"",
    "lint-fix": "eslint . \"./src/**/*.{ts,js,cjs,mjs,vue}\" --fix",
    "test": "vitest --passWithNoTests",
    "test:e2e": "playwright test",
    "test:storybook": "vitest --project=storybook --run",
    "type-check": "vue-tsc --build --noEmit",
    "generate-openapi": "openapi-typescript ../../open-api/menu-api.json --output ./src/generated/open-api/menu-api.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@auth0/auth0-vue": "^2.5.0",
    "@quasar/extras": "^1.17.0",
    "@tanstack/vue-query": "^5.95.2",
    "@tanstack/vue-query-devtools": "^6.1.10",
    "autoprefixer": "^10.4.27",
    "openapi-fetch": "^0.17.0",
    "pinia": "^3.0.4",
    "quasar": "^2.19.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vue": "^3.5.31",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@quasar/app-vite": "^2.5.4",
    "@quasar/vite-plugin": "^1.11.0",
    "@storybook/addon-a11y": "^10.3.3",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/addon-links": "^10.3.3",
    "@storybook/addon-vitest": "^10.3.3",
    "@storybook/vue3-vite": "^10.3.3",
    "@tanstack/eslint-plugin-query": "^5.95.2",
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/browser-playwright": "4.1.2",
    "@vitest/coverage-v8": "4.1.2",
    "@vitest/eslint-plugin": "^1.6.13",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.1.0",
    "eslint-plugin-playwright": "^2.10.1",
    "eslint-plugin-storybook": "^10.3.3",
    "eslint-plugin-vue": "~10.8.0",
    "globals": "^17.5.0",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.1",
    "msw": "^2.12.14",
    "msw-storybook-addon": "^2.0.6",
    "npm-run-all2": "^8.0.4",
    "openapi-typescript": "^7.13.0",
    "playwright": "^1.58.2",
    "prettier": "3.8.1",
    "sass-embedded": "^1.98.0",
    "storybook": "^10.3.3",
    "typescript": "~6.0.2",
    "vite": "^8.0.3",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vitest": "^4.1.2",
    "vue-tsc": "^3.2.6"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1"
  },
  "packageManager": "pnpm@10.31.0+sha512.e3927388bfaa8078ceb79b748ffc1e8274e84d75163e67bc22e06c0d3aed43dd153151cbf11d7f8301ff4acb98c68bdc5cadf6989532801ffafe3b3e4a63c268",
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
