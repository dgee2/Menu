{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": ["env.d.ts", "src/**/*", "src/**/*.vue"],
  "exclude": ["src/**/__tests__/*"],
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"],
      "@storybook-config/*": ["./.storybook/*"]
    },
    "tsBuildInfoFile": "./build/tsconfig.app.tsbuildinfo"
  }
}
